QDialog, QMainWindow, QWidget {
    color: #dfffe8;
    background-color: #080c14;
    font-family: "Segoe UI";
    font-size: 10pt;
}

#LoginDialog {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #070b14,
                                stop:0.5 #101a2a,
                                stop:1 #070b14);
    border: 1px solid #1f4f35;
}

QLabel#lblTitle {
    font-size: 16pt;
    font-weight: 700;
    letter-spacing: 2px;
    color: #79ffb3;
    padding: 8px;
}

QLabel#lblStatus {
    color: #ff6b7f;
    font-weight: 600;
    min-height: 24px;
}

QLineEdit {
    background-color: #0f1a29;
    border: 1px solid #2f6b48;
    border-radius: 6px;
    padding: 7px 10px;
    selection-background-color: #2aa765;
    color: #e7fff0;
}

QLineEdit:focus {
    border: 1px solid #5df59c;
    background-color: #122338;
}

QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #0d3b23,
                                stop:1 #1a6e3f);
    border: 1px solid #67f0a1;
    border-radius: 8px;
    padding: 8px 14px;
    font-weight: 700;
    color: #f0fff6;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #145331,
                                stop:1 #228c50);
}

QPushButton:pressed {
    padding-top: 9px;
    padding-bottom: 7px;
}

QWidget#mainRoot {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #050912,
                                stop:0.45 #0a1626,
                                stop:1 #08101b);
}

QLabel#mainTitle {
    color: #98ffc3;
    font-size: 14pt;
    font-weight: 700;
    letter-spacing: 1px;
}

QLabel#helpLabel {
    color: #b9d9c7;
    padding: 6px;
    border: 1px solid #264b39;
    border-radius: 8px;
    background-color: #0b1422;
}

QLabel#statusLabel {
    color: #84ffba;
    background-color: #0b1422;
    border: 1px solid #2a5f45;
    border-radius: 8px;
    padding: 8px;
    font-weight: 600;
}

QWidget#paintCanvas {
    border: 1px solid #2f6f4f;
    border-radius: 10px;
    background-color: #ffffff;
}
